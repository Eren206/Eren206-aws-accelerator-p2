## Example .env for local development
# Copy this to .env and fill real secrets. Do NOT commit .env to VCS.

# Frontend URL used for CORS
FRONTEND_URL=http://localhost:3000

# HTTP server port
PORT=3000

# DynamoDB single-table name
EHR_TABLE_NAME=your-ehr-table-name

# S3 bucket used to store documents
DOCUMENTS_BUCKET_NAME=your-documents-bucket

# Groq API key for LLM calls
GROQ_API_KEY=replace-me

# API Gateway (used by kill-switch lambda)
API_GATEWAY_ID=rest-api-id
STAGE_NAME=prod

# AWS credentials / region (or configure via AWS CLI)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# CI / notifications
NOTIFICATION_EMAIL=ops@example.com

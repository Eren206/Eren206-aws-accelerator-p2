{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc",
    "build:frontend": "node frontend/build.mjs",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main",
    "start:dev": "ts-node src/main.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed": "ts-node src/scripts/seed.ts",
    "bundle": "esbuild dist/serverless.js --bundle --platform=node --target=node20 --outfile=dist/serverless-bundle.js --external:\"@aws-sdk/*\" --external:\"aws-sdk\" && esbuild dist/worker.js --bundle --platform=node --target=node20 --outfile=dist/worker-bundle.js --external:\"@aws-sdk/*\" --external:\"aws-sdk\" && esbuild dist/kill-switch.js --bundle --platform=node --target=node20 --outfile=dist/kill-switch-bundle.js --external:\"@aws-sdk/*\" --external:\"aws-sdk\""
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.1058.0",
    "@aws-sdk/client-dynamodb": "^3.1058.0",
    "@aws-sdk/client-s3": "^3.1058.0",
    "@aws-sdk/client-sqs": "^3.1058.0",
    "@aws-sdk/lib-dynamodb": "^3.1058.0",
    "@hono/node-server": "^1.19.14",
    "dotenv": "^17.4.2",
    "hono": "^4.12.23",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.41",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
